# Configuración del Servidor
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000

# Configuración de MongoDB
# Para desarrollo local
MONGODB_URI=mongodb://localhost:27017/todo_app

# Para producción con autenticación (opcional)
# MONGODB_URI=mongodb://admin:password123@localhost:27017/todo_app?authSource=admin

# Para usar MongoDB Atlas (nube)
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/todo_app?retryWrites=true&w=majority