# Configuración del Servidor
PORT=3000
NODE_ENV=development
mongoose.connect('mongodb://localhost:27017/todo_app')
# Configuración de MongoDB
MONGO_URI=mongodb://localhost:27017/todo_app

# Para producción con autenticación (opcional)
# MONGO_URI=mongodb://admin:password123@localhost:27017/todo_app?authSource=admin

# Para usar MongoDB Atlas (nube)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/todo_app?retryWrites=true&w=majority
